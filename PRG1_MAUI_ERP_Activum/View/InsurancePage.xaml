<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.InsurancePage"
             Title="Försäkringar">

    <Grid RowDefinitions="Auto, Auto, Auto, *" Padding="20" RowSpacing="15">

        <SearchBar Grid.Row="1" Placeholder="Sök på typ eller kundnummer..."
               SearchCommand="{Binding SearchCommand}"
               SearchCommandParameter="{Binding Text, Source={RelativeSource Self}}" />

        <HorizontalStackLayout Grid.Row="2" Spacing="10" HorizontalOptions="Center">
            <Entry Placeholder="Typ (ex. Bil)" Text="{Binding NewInsuranceType}" WidthRequest="110" BackgroundColor="White" TextColor="Black"/>
            <Entry Placeholder="Pris/år" Text="{Binding NewPremium}" WidthRequest="90" Keyboard="Numeric" BackgroundColor="White" TextColor="Black"/>
            <Entry Placeholder="Status" Text="{Binding NewStatus}" WidthRequest="90" BackgroundColor="White" TextColor="Black"/>
            <Entry Placeholder="Kund ID" Text="{Binding NewCustomerId}" WidthRequest="100" BackgroundColor="White" TextColor="Black"/>
            <Button Text="Lägg till" Command="{Binding AddInsuranceCommand}" BackgroundColor="#134f5c" TextColor="White"/>
        </HorizontalStackLayout>

        <Grid Grid.Row="3" RowDefinitions="Auto, *">
            <Grid Grid.Row="0" ColumnDefinitions="2*, 1*, 1*, 1.5*, *" Padding="10" BackgroundColor="#134f5c">
                <Label Text="Försäkring" TextColor="White" FontAttributes="Bold" />
                <Label Grid.Column="1" Text="Pris/år" TextColor="White" FontAttributes="Bold" />
                <Label Grid.Column="2" Text="Status" TextColor="White" FontAttributes="Bold" />
                <Label Grid.Column="3" Text="Kund ID" TextColor="White" FontAttributes="Bold" />
                <Label Grid.Column="4" Text="Åtgärd" TextColor="White" FontAttributes="Bold" />
            </Grid>

            <CollectionView Grid.Row="1" ItemsSource="{Binding DisplayInsurances}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="2*, 1*, 1*, 1.5*, *" Padding="10">
                            <Label Text="{Binding InsuranceType}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding Premium}" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text="{Binding Status}" VerticalOptions="Center"/>
                        <Label Grid.Column="3" Text="{Binding CustomerId}" VerticalOptions="Center"/>
                        <Button Grid.Column="4" Text="Ta bort" Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.RemoveInsuranceCommand}" CommandParameter="{Binding .}" BackgroundColor="Red" TextColor="White" Padding="5" HeightRequest="35"/>
                    </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>